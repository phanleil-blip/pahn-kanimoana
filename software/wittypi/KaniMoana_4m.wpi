# Turns on RPi every 30 minutes on the 30 and 60 min marks

BEGIN	2015-08-01 00:00:00
END	2035-07-31 23:59:59

# -- turn on for "26 min" and wait for shutdown
# -- should start up every 30 minutes, as long as shutdown is not missed
# -- use default ON setting
# -- allows battery swapping

ON	M26     WAIT   # keep ON state for 26 minutes
OFF	M4            # keep OFF until 30 min mark
